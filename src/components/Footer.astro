---
<footer style="
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 50;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 18px 40px;
  pointer-events: none;
">
  <span class="audiowide" style="
    color: #E5E5E5;
    font-size: clamp(10px, 0.85vw, 14px);
    letter-spacing: 0.08em;
    opacity: 0.8;
    pointer-events: none;
  ">
    © 2017-2026 DreamMachine All rights reserved.
  </span>

  <a
    href="https://marcobuhlmann.com"
    target="_blank"
    rel="noopener noreferrer"
    style="
      position: absolute;
      right: 40px;
      bottom: 14px;
      opacity: 0.7;
      transition: opacity 0.2s;
      pointer-events: all;
    "
    onmouseover="this.style.opacity='1'"
    onmouseout="this.style.opacity='0.7'"
    aria-label="Marco Buhlmann"
  >
    <img
      src="/assets/mb-logo-w.png"
      alt="MB"
      style="display:block;height:36px;width:auto;"
    />
  </a>
</footer>
