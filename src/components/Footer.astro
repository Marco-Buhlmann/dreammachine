<footer style="
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 50;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 16px 24px;
  pointer-events: none;
">
  <!-- Centered copyright -->
  <span style="
    color: rgba(255,255,255,0.5);
    font-size: 11px;
    letter-spacing: 0.1em;
    pointer-events: none;
  ">
    © 2017-2026 DreamMachine All rights reserved.
  </span>

  <!-- MB logo — bottom right, links to marcobuhlmann.com -->
  <a
    href="https://marcobuhlmann.com"
    target="_blank"
    rel="noopener noreferrer"
    style="
      position: absolute;
      right: 24px;
      bottom: 12px;
      opacity: 0.5;
      transition: opacity 0.2s;
      pointer-events: all;
    "
    onmouseover="this.style.opacity='1'"
    onmouseout="this.style.opacity='0.5'"
    aria-label="Marco Buhlmann"
  >
    <img
      src="/assets/mb-logo.png"
      alt="MB"
      width="28"
      height="28"
      style="display: block; filter: invert(1);"
    />
  </a>
</footer>
