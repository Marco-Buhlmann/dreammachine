---
---
<footer class="dm-footer">
  <span class="audiowide dm-footer-copy">
    © 2017-2026 DreamMachine All rights reserved.
  </span>

  <a
    href="https://marcobuhlmann.com"
    target="_blank"
    rel="noopener noreferrer"
    class="dm-footer-logo"
    onmouseover="this.style.opacity='1'"
    onmouseout="this.style.opacity='0.7'"
    aria-label="Marco Buhlmann"
  >
    <img src="/assets/mb-logo-w.png" alt="MB" class="dm-footer-mb" />
  </a>
</footer>

<style>
  .dm-footer {
    position: fixed;
    bottom: 0; left: 0; right: 0;
    z-index: 50;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 15px 40px;
    background: rgba(0,0,0,0.88);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-top: 1px solid rgba(255,255,255,0.07);
    pointer-events: none;
  }
  .dm-footer-copy {
    color: #E5E5E5;
    font-size: clamp(10px, 0.85vw, 14px);
    letter-spacing: 0.08em;
    opacity: 0.8;
    pointer-events: none;
  }
  .dm-footer-logo {
    position: absolute;
    right: 40px;
    bottom: 14px;
    opacity: 0.7;
    transition: opacity 0.2s;
    pointer-events: all;
  }
  .dm-footer-mb {
    display: block;
    height: 36px;
    width: auto;
  }

  /* ── Mobile ── */
  @media (max-width: 640px) {
    .dm-footer {
      padding: 12px 20px;
    }
    .dm-footer-copy {
      font-size: 9px;
      letter-spacing: 0.06em;
    }
    .dm-footer-logo {
      right: 16px;
      bottom: 10px;
    }
    .dm-footer-mb {
      height: 26px;
    }
  }
</style>
