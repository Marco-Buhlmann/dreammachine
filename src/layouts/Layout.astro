---
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'DreamMachine',
  description = 'Creators of immersive experiences through art, music, and technology.',
} = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="DreamMachine" />
    <meta property="og:url" content="https://www.dreammachine.vision" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Audiowide = the original DreamMachine brand font -->
    <link href="https://fonts.googleapis.com/css2?family=Audiowide&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
    <style is:global>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; }
      body {
        background: #000;
        color: #fff;
        font-family: 'Inter', sans-serif;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }
      .audiowide { font-family: 'Audiowide', sans-serif; }
      @keyframes marquee {
        from { transform: translateX(0); }
        to   { transform: translateX(-50%); }
      }
      /* Top + bottom glow that fades to transparent at edges — no side borders */
      .btn-glow { position: relative; }
      .btn-glow::before,
      .btn-glow::after {
        content: '';
        position: absolute;
        left: 0; right: 0;
        height: 1px;
        background: linear-gradient(
          to right,
          transparent 0%,
          rgba(255,255,255,0.7) 30%,
          rgba(255,255,255,0.7) 70%,
          transparent 100%
        );
        pointer-events: none;
      }
      .btn-glow::before { top: 0; }
      .btn-glow::after  { bottom: 0; }
    </style>
  </head>
  <body>
    <slot />
    <Footer />
  </body>
</html>
