---
import Layout from '@/layouts/Layout.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
---

<Layout title="Events — DreamMachine">
  <Nav />
  <main class="relative z-10 flex flex-col items-center justify-center min-h-screen px-6 text-center">
    <h1 class="text-white text-xs tracking-[0.4em] uppercase mb-12 opacity-40">Events</h1>
    <p class="text-white/20 text-sm max-w-md">
      Upcoming experiences and events.
    </p>
  </main>
  <Footer />
</Layout>
