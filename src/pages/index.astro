---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
---

<Layout title="DreamMachine">
  <Nav />

  <!-- Full-screen video background -->
  <div style="position:fixed;inset:0;z-index:0;overflow:hidden;">
    <video
      autoplay loop muted playsinline
      style="width:100%;height:100%;object-fit:cover;"
    >
      <source src="/assets/dm-lp-26.mp4" type="video/mp4" />
    </video>
    <div style="position:absolute;inset:0;background:rgba(0,0,0,0.2);"></div>
  </div>

  <main style="
    position: relative;
    z-index: 10;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  ">

    <!-- OWL · EVENTS buttons — pinned below the video's owl icon (~68% from top) -->
    <div style="
      position: absolute;
      top: 68%;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      align-items: center;
      gap: clamp(12px,1.5vw,24px);
    ">
      <a href="/owl" class="audiowide btn-glow" style="
        color: #C9A97A;
        font-size: clamp(0.55rem, 1.1vw, 0.85rem);
        letter-spacing: 0.2em;
        text-decoration: none;
        padding: 8px 0;
        width: clamp(120px, 12vw, 200px);
        text-align: center;
        background: rgba(14, 31, 47, 0.40);
        border-radius: 20px;
        transition: background 0.25s, color 0.25s;
        white-space: nowrap;
        display: inline-block;
      "
      onmouseover="this.style.background='rgba(14,31,47,0.7)';this.style.color='#e8c99a'"
      onmouseout="this.style.background='rgba(14,31,47,0.40)';this.style.color='#C9A97A'"
      >O W L</a>

      <a href="/experience" class="audiowide btn-glow" style="
        color: #C9A97A;
        font-size: clamp(0.55rem, 1.1vw, 0.85rem);
        letter-spacing: 0.2em;
        text-decoration: none;
        padding: 8px 0;
        width: clamp(120px, 12vw, 200px);
        text-align: center;
        background: rgba(14, 31, 47, 0.40);
        border-radius: 20px;
        transition: background 0.25s, color 0.25s;
        white-space: nowrap;
        display: inline-block;
      "
      onmouseover="this.style.background='rgba(14,31,47,0.7)';this.style.color='#e8c99a'"
      onmouseout="this.style.background='rgba(14,31,47,0.40)';this.style.color='#C9A97A'"
      >E V E N T S</a>
    </div>
  </main>


</Layout>

