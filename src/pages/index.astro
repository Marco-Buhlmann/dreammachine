---
import Layout from '@/layouts/Layout.astro';
import Nav from '@/components/Nav.astro';
import Footer from '@/components/Footer.astro';
---

<Layout title="DreamMachine — Immersive Experience Creator">
  <Nav />

  <!-- Animated background -->
  <div
    id="dm-bg"
    class="fixed inset-0 z-0"
    style="
      background: radial-gradient(ellipse at 20% 50%, #1a0533 0%, transparent 60%),
                  radial-gradient(ellipse at 80% 20%, #0d1f3c 0%, transparent 60%),
                  radial-gradient(ellipse at 60% 80%, #0f1a00 0%, transparent 60%),
                  #000;
      animation: bgpan 15s ease-in-out infinite alternate;
    "
  ></div>

  <!-- Hero -->
  <main class="relative z-10 flex flex-col items-center justify-center min-h-screen px-6 text-center">

    <!-- Scrolling marquee row -->
    <div class="overflow-hidden w-full mb-6 opacity-10 pointer-events-none select-none">
      <div class="flex whitespace-nowrap" style="animation: marquee 25s linear infinite;">
        {Array.from({length: 6}).map(() => (
          <span class="text-white text-xs tracking-[0.5em] uppercase mx-8">
            [Immersive + Experience + Creator]&nbsp;&nbsp;&nbsp;
          </span>
        ))}
      </div>
    </div>

    <!-- Main title -->
    <h1 class="text-white font-light leading-none mb-10" style="font-size: clamp(2.5rem, 8vw, 7rem); letter-spacing: -0.02em;">
      [Immersive<br/>
      <span class="opacity-40">+</span><br/>
      Experience<br/>
      <span class="opacity-40">+</span><br/>
      Creator]
    </h1>

    <!-- CTA links -->
    <div class="flex items-center gap-10 mt-4">
      <a
        href="/owl"
        class="text-white text-xs tracking-[0.3em] uppercase border-b border-white/20 pb-1 hover:border-white/80 transition-colors duration-300"
      >
        OWL
      </a>
      <span class="text-white/20">·</span>
      <a
        href="/experience"
        class="text-white text-xs tracking-[0.3em] uppercase border-b border-white/20 pb-1 hover:border-white/80 transition-colors duration-300"
      >
        Experiences
      </a>
      <span class="text-white/20">·</span>
      <a
        href="https://open.spotify.com/playlist/0po8Elt4Mqje3HwKV6a05U?si=8d0273f371d64f8b"
        target="_blank"
        rel="noopener noreferrer"
        class="text-white text-xs tracking-[0.3em] uppercase border-b border-white/20 pb-1 hover:border-white/80 transition-colors duration-300"
      >
        Spotify
      </a>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  @keyframes bgpan {
    0%   { background-position: 0% 50%; filter: hue-rotate(0deg); }
    50%  { background-position: 100% 50%; filter: hue-rotate(30deg); }
    100% { background-position: 0% 50%; filter: hue-rotate(0deg); }
  }
  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
</style>
