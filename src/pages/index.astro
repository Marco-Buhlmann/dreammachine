---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
---

<Layout title="DreamMachine">
  <Nav />

  <!-- Full-screen video background -->
  <div style="position:fixed;inset:0;z-index:0;overflow:hidden;">
    <video
      autoplay loop muted playsinline
      style="width:100%;height:100%;object-fit:cover;"
    >
      <source src="/assets/dm-lp-26.mp4" type="video/mp4" />
    </video>
    <div style="position:absolute;inset:0;background:rgba(0,0,0,0.2);"></div>
  </div>

  <main style="
    position: relative;
    z-index: 10;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  ">

    <!-- Scrolling marquee — 75% opacity, fades 15% in from each edge -->
    <div style="
      position: absolute;
      top: 120px;
      left: 0;
      right: 0;
      overflow: hidden;
      opacity: 0.75;
      pointer-events: none;
      user-select: none;
      -webkit-mask-image: linear-gradient(to right, transparent 0%, black 45%, black 55%, transparent 100%);
      mask-image: linear-gradient(to right, transparent 0%, black 45%, black 55%, transparent 100%);
    ">
      <div style="
        display: flex;
        width: max-content;
        animation: marquee 55s linear infinite;
      ">
        {Array.from({length: 8}).map(() => (
          <span class="audiowide" style="
            color: #E5E5E5;
            font-size: clamp(12px, 1.6vw, 24px);
            white-space: nowrap;
            padding: 0 3rem;
            line-height: 1.2;
          ">
            [Immersive + Experience + Creator]
          </span>
        ))}
      </div>
    </div>

    <!-- OWL · EVENTS buttons — pinned below the video's owl icon (~68% from top) -->
    <div style="
      position: absolute;
      top: 68%;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      align-items: center;
      gap: clamp(12px,1.5vw,24px);
    ">
      <a href="/owl" class="audiowide btn-glow" style="
        color: #C9A97A;
        font-size: clamp(0.55rem, 1.1vw, 0.85rem);
        letter-spacing: 0.2em;
        text-decoration: none;
        padding: 8px 0;
        width: clamp(120px, 12vw, 200px);
        text-align: center;
        background: rgba(14, 31, 47, 0.40);
        border-radius: 20px;
        transition: background 0.25s, color 0.25s;
        white-space: nowrap;
        display: inline-block;
      "
      onmouseover="this.style.background='rgba(14,31,47,0.7)';this.style.color='#e8c99a'"
      onmouseout="this.style.background='rgba(14,31,47,0.40)';this.style.color='#C9A97A'"
      >O W L</a>

      <a href="/experience" class="audiowide btn-glow" style="
        color: #C9A97A;
        font-size: clamp(0.55rem, 1.1vw, 0.85rem);
        letter-spacing: 0.2em;
        text-decoration: none;
        padding: 8px 0;
        width: clamp(120px, 12vw, 200px);
        text-align: center;
        background: rgba(14, 31, 47, 0.40);
        border-radius: 20px;
        transition: background 0.25s, color 0.25s;
        white-space: nowrap;
        display: inline-block;
      "
      onmouseover="this.style.background='rgba(14,31,47,0.7)';this.style.color='#e8c99a'"
      onmouseout="this.style.background='rgba(14,31,47,0.40)';this.style.color='#C9A97A'"
      >E V E N T S</a>
    </div>
  </main>


</Layout>

<style>
  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
</style>
