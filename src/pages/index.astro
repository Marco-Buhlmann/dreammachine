---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="DreamMachine">
  <Nav />

  <!-- Full-screen video background -->
  <div style="position:fixed;inset:0;z-index:0;overflow:hidden;">
    <video
      autoplay loop muted playsinline
      style="width:100%;height:100%;object-fit:cover;"
    >
      <source src="/assets/dm-lp-26.mp4" type="video/mp4" />
    </video>
    <div style="position:absolute;inset:0;background:rgba(0,0,0,0.2);"></div>
  </div>

  <main style="
    position: relative;
    z-index: 10;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  ">

    <!-- Scrolling marquee -->
    <div style="
      position: absolute;
      top: 120px;
      left: 0;
      right: 0;
      overflow: hidden;
      pointer-events: none;
      user-select: none;
    ">
      <div style="
        display: flex;
        width: max-content;
        animation: marquee 44s linear infinite;
      ">
        {Array.from({length: 6}).map(() => (
          <span class="audiowide" style="
            color: #E5E5E5;
            font-size: clamp(24px, 3.2vw, 48px);
            white-space: nowrap;
            padding: 0 4rem;
            line-height: 1.2;
          ">
            [Immersive + Experience + Creator]
          </span>
        ))}
      </div>
    </div>

    <!-- Gold owl logo — centered above buttons -->
    <img
      src="/assets/owl-gold.png"
      alt="DreamMachine OWL"
      style="
        width: clamp(160px, 16vw, 260px);
        height: auto;
        filter: drop-shadow(0 0 40px rgba(201,169,122,0.3));
        margin-bottom: 2rem;
      "
    />

    <!-- OWL · EVENTS pill buttons — centered, gold #C9A97A, dark navy bg, white border -->
    <div style="display:flex;align-items:center;gap:clamp(16px,2vw,32px);margin-top:0;">
      <a href="/owl" class="audiowide" style="
        color: #C9A97A;
        font-size: clamp(1rem, 2vw, 1.5rem);
        letter-spacing: 0.2em;
        text-decoration: none;
        padding: 12px clamp(28px, 4vw, 56px);
        background: rgba(14, 31, 47, 0.40);
        border: 3px solid #fff;
        border-radius: 20px;
        transition: background 0.25s, color 0.25s;
        white-space: nowrap;
      "
      onmouseover="this.style.background='rgba(14,31,47,0.7)';this.style.color='#e8c99a'"
      onmouseout="this.style.background='rgba(14,31,47,0.40)';this.style.color='#C9A97A'"
      >O W L</a>

      <a href="/experience" class="audiowide" style="
        color: #C9A97A;
        font-size: clamp(1rem, 2vw, 1.5rem);
        letter-spacing: 0.2em;
        text-decoration: none;
        padding: 12px clamp(28px, 4vw, 56px);
        background: rgba(14, 31, 47, 0.40);
        border: 3px solid #fff;
        border-radius: 20px;
        transition: background 0.25s, color 0.25s;
        white-space: nowrap;
      "
      onmouseover="this.style.background='rgba(14,31,47,0.7)';this.style.color='#e8c99a'"
      onmouseout="this.style.background='rgba(14,31,47,0.40)';this.style.color='#C9A97A'"
      >E V E N T S</a>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
</style>
