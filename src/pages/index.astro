---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="DreamMachine">
  <Nav />

  <!-- Full-screen video background -->
  <div style="position:fixed;inset:0;z-index:0;overflow:hidden;">
    <video
      id="bg-video"
      autoplay
      loop
      muted
      playsinline
      style="width:100%;height:100%;object-fit:cover;"
    >
      <source src="/assets/dm-main.mp4" type="video/mp4" />
    </video>
    <!-- Dark overlay so text is legible -->
    <div style="position:absolute;inset:0;background:rgba(0,0,0,0.35);"></div>
  </div>

  <!-- Hero content -->
  <main style="
    position: relative;
    z-index: 10;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  ">

    <!-- Scrolling marquee -->
    <div style="
      position: absolute;
      top: 80px;
      left: 0;
      right: 0;
      overflow: hidden;
      opacity: 0.55;
      pointer-events: none;
      user-select: none;
    ">
      <div style="
        display: flex;
        width: max-content;
        animation: marquee 22s linear infinite;
      ">
        {Array.from({length: 8}).map(() => (
          <span style="
            color: #fff;
            font-size: 13px;
            letter-spacing: 0.45em;
            text-transform: uppercase;
            white-space: nowrap;
            padding: 0 2rem;
            font-family: 'Audiowide', sans-serif;
          ">
            [Immersive + Experience + Creator]
          </span>
        ))}
      </div>
    </div>

    <!-- Owl logo -->
    <img
      src="/assets/owl-white.png"
      alt="DreamMachine OWL"
      style="
        width: clamp(180px, 25vw, 280px);
        height: auto;
        filter: drop-shadow(0 0 40px rgba(255,255,255,0.15));
        margin-bottom: 2.5rem;
      "
    />

    <!-- OWL · EVENTS buttons -->
    <div style="display:flex;align-items:center;gap:3rem;">
      <a href="/owl" style="
        color: #fff;
        font-size: 11px;
        letter-spacing: 0.45em;
        text-transform: uppercase;
        text-decoration: none;
        border-bottom: 1px solid rgba(255,255,255,0.4);
        padding-bottom: 4px;
        transition: border-color 0.3s;
        font-family: 'Audiowide', sans-serif;
      "
      onmouseover="this.style.borderColor='rgba(255,255,255,0.9)'"
      onmouseout="this.style.borderColor='rgba(255,255,255,0.4)'"
      >OWL</a>

      <a href="/experience" style="
        color: #fff;
        font-size: 11px;
        letter-spacing: 0.45em;
        text-transform: uppercase;
        text-decoration: none;
        border-bottom: 1px solid rgba(255,255,255,0.4);
        padding-bottom: 4px;
        transition: border-color 0.3s;
        font-family: 'Audiowide', sans-serif;
      "
      onmouseover="this.style.borderColor='rgba(255,255,255,0.9)'"
      onmouseout="this.style.borderColor='rgba(255,255,255,0.4)'"
      >EVENTS</a>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  @keyframes marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
</style>
