---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="OWL — DreamMachine">
  <Nav />

  <!-- ── HERO: Fire background ──────────────────────────────────── -->
  <section style="
    position:relative;
    min-height:85vh;
    display:flex;
    align-items:flex-end;
    padding:0 5vw 5rem;
    overflow:hidden;
  ">
    <!-- Fire gradient background -->
    <div style="
      position:absolute;inset:0;
      background:
        radial-gradient(ellipse at 50% 120%, #ff6600 0%, #cc3300 20%, #661100 45%, #1a0800 70%, #000 100%);
      animation: fireflicker 4s ease-in-out infinite alternate;
    "></div>
    <!-- Noise texture overlay -->
    <div style="position:absolute;inset:0;background:rgba(0,0,0,0.4);"></div>

    <!-- Gold owl logo centered at top -->
    <img
      src="/assets/owl-gold.png"
      alt="DreamMachine OWL"
      style="
        position:absolute;
        top:50%;left:50%;
        transform:translate(-50%,-60%);
        width:clamp(160px,22vw,260px);
        height:auto;
        filter:drop-shadow(0 0 60px rgba(255,140,0,0.5));
      "
    />

    <!-- Title bottom left -->
    <div style="position:relative;z-index:2;">
      <p class="audiowide" style="color:rgba(255,200,100,0.5);font-size:11px;letter-spacing:0.3em;text-transform:uppercase;margin-bottom:0.5rem;">
        DreamMachine
      </p>
      <h1 class="audiowide" style="
        color:#fff;
        font-size:clamp(2.5rem,6vw,5rem);
        line-height:1;
        letter-spacing:0.05em;
      ">OWL</h1>
    </div>
  </section>

  <!-- ── SECTIONS ────────────────────────────────────────────────── -->
  <div style="background:#0a0a0a;">

    <!-- 1. Curiouser & Curiouser -->
    <section style="
      display:grid;
      grid-template-columns:1fr 1fr;
      align-items:center;
      gap:0;
      min-height:60vh;
      border-bottom:1px solid rgba(255,255,255,0.05);
    ">
      <div style="padding:5rem 5vw;">
        <h2 class="audiowide" style="
          color:#fff;
          font-size:clamp(1.6rem,3.5vw,3rem);
          line-height:1.1;
          margin-bottom:1.5rem;
        ">
          Curiouser &<br/>Curiouser.
        </h2>
        <p style="color:rgba(255,255,255,0.4);font-size:14px;line-height:1.8;max-width:400px;">
          OWL is an immersive art installation and live experience concept born from the intersection of sculpture, sound, and spectacle. A creature of curiosity, built to provoke wonder.
        </p>
      </div>
      <!-- D·D badge -->
      <div style="
        display:flex;align-items:center;justify-content:center;
        background:#111;min-height:60vh;
      ">
        <div style="
          width:180px;height:180px;
          background:#1a1a1a;
          border-radius:50%;
          display:flex;align-items:center;justify-content:center;
          border:1px solid rgba(255,200,80,0.2);
        ">
          <span class="audiowide" style="
            color:rgba(255,200,80,0.6);
            font-size:2.2rem;
            letter-spacing:0.15em;
          ">D·D</span>
        </div>
      </div>
    </section>

    <!-- 2. Nothing to Defend -->
    <section style="
      display:grid;
      grid-template-columns:1fr 1fr;
      align-items:center;
      gap:0;
      min-height:60vh;
      border-bottom:1px solid rgba(255,255,255,0.05);
      direction:rtl;
    ">
      <div style="padding:5rem 5vw;direction:ltr;">
        <h2 class="audiowide" style="
          color:#fff;
          font-size:clamp(1.6rem,3.5vw,3rem);
          line-height:1.1;
          margin-bottom:1.5rem;
        ">
          Nothing to<br/>Defend.
        </h2>
        <p style="color:rgba(255,255,255,0.4);font-size:14px;line-height:1.8;max-width:400px;">
          The OWL stands as a symbol of fearless presence. Unguarded. Open. A space where art meets audience without pretense, and where every encounter becomes part of the experience.
        </p>
      </div>
      <!-- M·M badge -->
      <div style="
        display:flex;align-items:center;justify-content:center;
        background:#0f0f0f;min-height:60vh;direction:ltr;
      ">
        <div style="
          width:180px;height:180px;
          background:#1a1a1a;
          border-radius:50%;
          display:flex;align-items:center;justify-content:center;
          border:1px solid rgba(255,200,80,0.2);
        ">
          <span class="audiowide" style="
            color:rgba(255,200,80,0.6);
            font-size:2.2rem;
            letter-spacing:0.15em;
          ">M·M</span>
        </div>
      </div>
    </section>

    <!-- 3. Imaginative Fusion -->
    <section style="
      display:grid;
      grid-template-columns:1fr 1fr;
      align-items:center;
      gap:0;
      min-height:60vh;
      border-bottom:1px solid rgba(255,255,255,0.05);
    ">
      <div style="padding:5rem 5vw;">
        <h2 class="audiowide" style="
          color:#fff;
          font-size:clamp(1.6rem,3.5vw,3rem);
          line-height:1.1;
          margin-bottom:1.5rem;
        ">
          Imaginative<br/>Fusion.
        </h2>
        <p style="color:rgba(255,255,255,0.4);font-size:14px;line-height:1.8;max-width:400px;">
          Forged from steel, driven by imagination. OWL merges fabrication and fantasy — a physical embodiment of DreamMachine's commitment to building experiences that live between the real and the surreal.
        </p>
      </div>
      <div style="
        display:flex;align-items:center;justify-content:center;
        background:#111;min-height:60vh;
      ">
        <img
          src="/assets/owl-gold.png"
          alt="OWL"
          style="width:160px;height:auto;opacity:0.7;filter:drop-shadow(0 0 30px rgba(255,150,0,0.3));"
        />
      </div>
    </section>

    <!-- 4. Expression Builder -->
    <section style="
      display:grid;
      grid-template-columns:1fr 1fr;
      align-items:center;
      gap:0;
      min-height:60vh;
      border-bottom:1px solid rgba(255,255,255,0.05);
      direction:rtl;
    ">
      <div style="padding:5rem 5vw;direction:ltr;">
        <h2 class="audiowide" style="
          color:#fff;
          font-size:clamp(1.6rem,3.5vw,3rem);
          line-height:1.1;
          margin-bottom:1.5rem;
        ">
          Expression<br/>Builder.
        </h2>
        <p style="color:rgba(255,255,255,0.4);font-size:14px;line-height:1.8;max-width:400px;">
          Every detail of OWL is an act of expression. From the spread of its wings to the intensity of its gaze — it was built to be felt. A platform for artists and audiences to expand what's possible.
        </p>
      </div>
      <div style="
        display:flex;align-items:center;justify-content:center;
        background:#0f0f0f;min-height:60vh;direction:ltr;
      ">
        <img
          src="/assets/owl-pic.png"
          alt="OWL installation"
          style="width:220px;height:auto;border-radius:4px;filter:drop-shadow(0 0 30px rgba(0,100,255,0.3));"
        />
      </div>
    </section>

  </div>

  <!-- ── PHOTO GALLERY ────────────────────────────────────────────── -->
  <section style="background:#0a0a0a;padding:4rem 5vw 8rem;">
    <div style="
      display:grid;
      grid-template-columns:repeat(4,1fr);
      gap:8px;
    ">
      <img src="/assets/owl-pic.png"    alt="OWL installation" style="width:100%;aspect-ratio:1;object-fit:cover;border-radius:4px;" />
      <img src="/assets/owl-build1.png" alt="OWL build"        style="width:100%;aspect-ratio:1;object-fit:cover;border-radius:4px;" />
      <img src="/assets/owl-build2.png" alt="OWL build"        style="width:100%;aspect-ratio:1;object-fit:cover;border-radius:4px;" />
      <img src="/assets/owl-gold.png"   alt="OWL logo"         style="width:100%;aspect-ratio:1;object-fit:contain;border-radius:4px;background:#111;padding:1rem;" />
    </div>
  </section>

  <Footer />
</Layout>

<style>
  @keyframes fireflicker {
    0%   { filter: brightness(1) saturate(1.2); }
    50%  { filter: brightness(1.15) saturate(1.4); }
    100% { filter: brightness(0.9) saturate(1.1); }
  }
  @media (max-width:700px) {
    section[style*="grid-template-columns:1fr 1fr"] {
      grid-template-columns: 1fr !important;
      direction: ltr !important;
    }
  }
</style>
