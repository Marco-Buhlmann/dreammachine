---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
---

<Layout title="OWL — DreamMachine">
  <Nav />

  <!-- ── HERO: Fire video + owl logo ──────────────────────── -->
  <section class="fire-section hero-section">
    <!-- Fire video background -->
    <video autoplay loop muted playsinline class="fire-video">
      <source src="/assets/dm-fire.mp4" type="video/mp4" />
    </video>
    <div class="fire-overlay"></div>

    <!-- Centred steel owl -->
    <div class="hero-owl">
      <img src="/assets/owl-steel.png" alt="DreamMachine OWL" class="hero-owl-img" />
    </div>

    <!-- title + description removed per design review -->
  </section>

  <!-- ── ORANGE INFO SECTION ─────────────────────────────────
       V-notch at top bites into fire hero; diagonal cut at bottom.
       z-index 3 so it layers above the fire section's bottom edge.
  ─────────────────────────────────────────────────────────── -->
  <section class="owl-info-section">
    <h2 class="audiowide owl-info-title">DreamMachine OWL</h2>
    <p class="owl-info-body">
      <strong>8FT tall art on fire piece</strong> created from 7'–10' Custom
      Steel. Pyro rigged across body and wings: 1/2&quot; pipe T‑Burner × 4
      var. width. Flame projectors on both wingtips create an x‑shooting flame
      effect. The wings are slotted into the body of the owl with hitch pins.
      The owl's body attaches to a baseplate w/ bolt plate or hitch pinned
      sleeve. Approximate weight 1200 lbs.
    </p>
  </section>

  <!-- ── CONTENT SECTIONS ──────────────────────────────────── -->
  <div class="sections-wrap">

    <!-- 1 · Curiouser & Curiouser  (text left, badge right) -->
    <section class="content-row">
      <div class="text-col">
        <h2 class="audiowide section-h2">Curiouser &amp;<br/>Curiouser.</h2>
        <p class="section-body">
          OWL is a creature of curiosity — built to provoke wonder.
          A live installation and experience concept born from art,
          music, and technology. Every encounter with OWL is designed
          to leave you asking more.
        </p>
      </div>
      <div class="badge-col">
        <div class="badge">
          <img src="/assets/owl-c1.png" alt="D+D" class="badge-img" />
        </div>
      </div>
    </section>

    <!-- 2 · Nothing to Defend  (badge left, text right) -->
    <section class="content-row reverse">
      <div class="text-col">
        <h2 class="audiowide section-h2">Nothing to<br/>Defend.</h2>
        <p class="section-body">
          The OWL stands as a symbol of fearless presence — unguarded
          and open. A space where art meets audience without pretense,
          and where every encounter becomes part of the experience.
        </p>
      </div>
      <div class="badge-col">
        <div class="badge">
          <img src="/assets/owl-c2.png" alt="M+M" class="badge-img" />
        </div>
      </div>
    </section>

    <!-- 3 · Imaginative Fusion  (text left, badge right) -->
    <section class="content-row">
      <div class="text-col">
        <h2 class="audiowide section-h2">Imaginative<br/>Fusion.</h2>
        <p class="section-body">
          Forged from steel, driven by imagination. OWL merges
          fabrication and fantasy — a physical embodiment of
          DreamMachine's commitment to building experiences that
          live between the real and the surreal.
        </p>
      </div>
      <div class="badge-col">
        <div class="badge">
          <img src="/assets/owl-c3.png" alt="OWL icon" class="badge-img" />
        </div>
      </div>
    </section>

    <!-- 4 · Expression Builder  (badge left, text right) -->
    <section class="content-row reverse">
      <div class="text-col">
        <h2 class="audiowide section-h2">Expression<br/>Builder.</h2>
        <p class="section-body">
          Every detail of OWL is an act of expression. From the
          spread of its wings to the intensity of its gaze — it was
          built to be felt. A platform for artists and audiences to
          expand what's possible.
        </p>
      </div>
      <div class="badge-col">
        <div class="badge">
          <img src="/assets/owl-c4.png" alt="OWL wings" class="badge-img" />
        </div>
      </div>
    </section>

  </div>

  <!-- ── BOTTOM GALLERY: Fire video + octagon photos ──────── -->
  <section class="fire-section gallery-section">
    <video autoplay loop muted playsinline class="fire-video">
      <source src="/assets/dm-fire.mp4" type="video/mp4" />
    </video>
    <div class="fire-overlay"></div>

    <div class="gallery-row">
      <div class="gallery-hex">
        <img src="/assets/owl-build1.png" alt="OWL build" />
      </div>
      <div class="gallery-hex">
        <img src="/assets/owl-build2.png" alt="OWL build" />
      </div>
      <div class="gallery-hex">
        <img src="/assets/owl-d1.png" alt="OWL neon" />
      </div>
      <div class="gallery-hex">
        <img src="/assets/owl-d2.png" alt="OWL display" />
      </div>
    </div>
  </section>


</Layout>

<style>
  /* ── Fire sections ── */
  .fire-section {
    position: relative;
    overflow: hidden;
  }
  .fire-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    animation: fireflicker 6s ease-in-out infinite alternate;
  }
  .fire-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.45);
  }
  @keyframes fireflicker {
    0%   { filter: brightness(1)    saturate(1.1); }
    50%  { filter: brightness(1.08) saturate(1.3); }
    100% { filter: brightness(0.92) saturate(1.0); }
  }

  /* ── Hero ── */
  .hero-section {
    min-height: 80vh;   /* halved from 160vh */
    display: flex;
    align-items: flex-end;
    padding: 0 5vw 4rem;
  }
  .hero-owl {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 2;
  }
  .hero-owl-img {
    width: clamp(285px, 37.5vw, 480px);  /* 2× original, −25% */
    height: auto;
    filter: drop-shadow(0 0 60px rgba(255,160,40,0.6));
  }
  .hero-title {
    position: relative;
    z-index: 2;
  }
  .hero-sub {
    color: rgba(201,169,122,0.6);
    font-size: 11px;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    margin-bottom: 0.4rem;
  }
  .hero-h1 {
    color: #fff;
    font-size: clamp(2.8rem, 6vw, 5.5rem);
    line-height: 1;
    letter-spacing: 0.06em;
  }
  .hero-desc {
    position: absolute;
    top: 2.5rem;
    right: 5vw;
    z-index: 2;
    color: rgba(255,255,255,0.55);
    font-size: clamp(11px, 1.1vw, 14px);
    line-height: 1.7;
    text-align: right;
  }

  /* ── Content sections ── */
  .sections-wrap { background: #0a0a0a; }
  .content-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  /* reverse = badge on left, text on right */
  .content-row.reverse .text-col  { order: 2; }
  .content-row.reverse .badge-col { order: 1; }

  .text-col {
    padding: 5rem 5vw;
  }
  .section-h2 {
    color: #fff;
    font-size: clamp(1.6rem, 3vw, 2.8rem);
    line-height: 1.1;
    margin-bottom: 1.4rem;
  }
  .section-body {
    color: rgba(255,255,255,0.38);
    font-size: clamp(13px, 1.1vw, 15px);
    line-height: 1.85;
    max-width: 420px;
  }

  /* Badge column — equal padding on all sides so top/bottom matches horizontal gap */
  .badge-col {
    display: flex;
    align-items: center;
    justify-content: center;
    background: #0f0f0f;
    /* horizontal gap = (50vw - badge-width) / 2 ≈ 6vw → match top/bottom */
    padding: clamp(40px, 6vw, 80px) 0;
  }
  /* Badge — octagon clip, image fills fully, no padding — 2× content sections */
  .badge {
    width: clamp(320px, 38vw, 520px);
    aspect-ratio: 1;
    clip-path: polygon(30% 0%, 70% 0%, 100% 30%, 100% 70%, 70% 100%, 30% 100%, 0% 70%, 0% 30%);
    overflow: hidden;
  }
  .badge-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Gallery section ── */
  .gallery-section {
    min-height: 50vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 5rem 5vw;
  }
  .gallery-row {
    position: relative;
    z-index: 2;
    display: flex;
    gap: clamp(16px, 2.5vw, 40px);
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
  }
  /* Octagon gallery — full-bleed image */
  .gallery-hex {
    width: clamp(160px, 20vw, 280px);
    aspect-ratio: 1;
    clip-path: polygon(30% 0%, 70% 0%, 100% 30%, 100% 70%, 70% 100%, 30% 100%, 0% 70%, 0% 30%);
    overflow: hidden;
    flex-shrink: 0;
  }
  .gallery-hex img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Orange info section ── */
  .owl-info-section {
    position: relative;
    z-index: 3;
    /* Pull up 100px so the V tip overlaps into the fire section's bottom */
    margin-top: -100px;
    /* V notch at top (100px deep), diagonal cut at bottom-right */
    clip-path: polygon(0 100px, 50% 0, 100% 100px, 100% calc(100% - 100px), 0 100%);
    background: linear-gradient(
      150deg,
      #5a1e00 0%,
      #a83800 15%,
      #d46000 35%,
      #e07800 50%,
      #c05500 70%,
      #7a2800 88%,
      #0a0800 100%
    );
    /* Extra padding to compensate for clip-path eating into content */
    padding: calc(100px + 3.5rem) 8vw calc(120px + 2.5rem);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 6vw, 6rem);
    align-items: center;
  }
  .owl-info-title {
    color: #fff;
    font-size: clamp(2rem, 4.5vw, 4.5rem);
    line-height: 1.05;
    letter-spacing: 0.02em;
  }
  .owl-info-body {
    color: rgba(255,255,255,0.82);
    font-size: clamp(13px, 1.15vw, 16px);
    line-height: 1.8;
  }
  .owl-info-body strong {
    color: #fff;
    font-weight: 600;
  }

  /* ── Responsive ── */
  @media (max-width: 720px) {
    .content-row {
      grid-template-columns: 1fr;
    }
    .content-row.reverse .text-col,
    .content-row.reverse .badge-col {
      order: unset;
    }
    .badge-col { min-height: 40vw; }
    .hero-desc { display: none; }
  }
</style>
